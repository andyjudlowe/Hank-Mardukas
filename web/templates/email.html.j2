<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width"></head>
<body style="margin:0;padding:0;background:#f4f5f7;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#1a1a2e;">
  <div style="max-width:640px;margin:0 auto;padding:24px 16px;">
    <h1 style="font-size:22px;margin:0 0 4px;">🐾 NYC Pet Matcher</h1>
    <p style="margin:0 0 20px;color:#555;font-size:14px;">
      {% if count %}{{ count }} new high-confidence match{{ 'es' if count != 1 else '' }} this week.
      {% else %}No new high-confidence matches this week — possible matches are on the dashboard.{% endif %}
    </p>

    {% for m in matches %}
    <div style="background:#fff;border:1px solid #e3e3ec;border-radius:12px;padding:16px;margin-bottom:16px;">
      <div style="font-weight:700;font-size:14px;color:#0a7d3b;margin-bottom:10px;">
        {{ m.confidence }}% confidence
        <span style="color:#999;font-weight:400;">
          (attributes {{ m.attr_score }}%{% if m.photo_score is not none %}, photo {{ m.photo_score }}%{% endif %})
        </span>
      </div>
      <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;">
        <tr>
          {% for side, label, color in [('lost','LOST','#c0392b'), ('found','FOUND','#0a7d3b')] %}
          {% set p = m[side] %}
          <td width="50%" valign="top" style="padding:6px;">
            <div style="font-size:11px;font-weight:700;color:{{ color }};letter-spacing:.5px;">{{ label }}</div>
            {% if p.photo %}
            <img src="{{ p.photo }}" alt="{{ label }} pet" width="100%"
                 style="border-radius:8px;max-height:200px;object-fit:cover;margin:6px 0;">
            {% else %}
            <div style="height:120px;background:#f0f0f5;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;margin:6px 0;">no photo</div>
            {% endif %}
            <div style="font-size:13px;line-height:1.5;">
              <strong>{{ p.name }}</strong><br>
              {{ p.species }}{% if p.breed %} · {{ p.breed }}{% endif %}<br>
              {% if p.colors %}{{ p.colors|join(', ') }}<br>{% endif %}
              {{ p.borough }}{% if p.date %} · {{ p.date }}{% endif %}<br>
              <a href="{{ p.detail_url }}" style="color:#2b6cb0;">View {{ p.source }} post →</a>
            </div>
          </td>
          {% endfor %}
        </tr>
      </table>
      <div style="font-size:12px;color:#666;margin-top:10px;border-top:1px solid #f0f0f5;padding-top:8px;">
        Why: {{ m.reasons|join(' · ') }}
      </div>
    </div>
    {% endfor %}

    <p style="text-align:center;margin:24px 0;">
      <a href="{{ dashboard_url }}" style="background:#2b6cb0;color:#fff;text-decoration:none;padding:10px 20px;border-radius:8px;font-size:14px;">See all possible matches →</a>
    </p>
    <p style="font-size:11px;color:#999;text-align:center;line-height:1.5;">
      Automated matches from public Petco Love Lost and Craigslist listings.
      These are <em>candidates</em>, not confirmed — always verify via the original post.
    </p>
  </div>
</body>
</html>
