# ---- Matching (Claude vision) ----
ANTHROPIC_API_KEY=sk-ant-...
# Vision model for photo confirmation. Default opus; switch to haiku to cut cost.
PETMATCH_VISION_MODEL=claude-opus-4-8
# Set to 1 to skip all photo (Claude) calls and run attribute-only matching.
PETMATCH_NO_PHOTO=0

# ---- Email (weekly digest) ----
# Delivery is "resend" or "smtp".
PETMATCH_EMAIL_BACKEND=resend
REPORT_EMAIL=andyjudlowe@gmail.com
REPORT_FROM=NYC Pet Matcher <onboarding@resend.dev>
RESEND_API_KEY=re_...
# SMTP fallback (only if PETMATCH_EMAIL_BACKEND=smtp). Use a Gmail App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=andyjudlowe@gmail.com
SMTP_PASS=your-16-char-app-password

# ---- Dashboard ----
# Public base URL where the dashboard is hosted (used in the email footer link).
PETMATCH_DASHBOARD_URL=https://andyjudlowe.github.io/Hank-Mardukas/

# ---- Tuning (optional; sensible defaults in config.py) ----
# PETMATCH_DATE_WINDOW_DAYS=60
# PETMATCH_MAX_MILES=5
# PETMATCH_ATTR_THRESHOLD=0.45
# PETMATCH_DASH_THRESHOLD=0.45
# PETMATCH_EMAIL_THRESHOLD=0.75
